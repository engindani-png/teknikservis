      <Card style={{padding:14}}><SLabel title="Kodlar"/><IRow label="Stok Kodu" value={s.stokKodu} mono/><IRow label="Üretici Kodu" value={s.ureticiKod} mono/><IRow label="ÜTS Kodu" value={s.utsKodu} mono/>{s.uretim&&<IRow label="Üretim Tarihi" value={s.uretim}/>}{s.sku&&<IRow label="SKT" value={s.sku}/>}</Card>
    </div>
    {myWaybills.length>0&&<Card style={{padding:14}}><SLabel title="İlgili İrsaliyeler" icon="🚚"/>{myWaybills.slice(0,3).map(w=>(<div key={w.id} onClick={()=>setShowWaybill(w)} className="rh" style={{display:"flex",justifyContent:"space-between",padding:"7px 0",borderBottom:`1px solid ${T.border}`,cursor:"pointer"}}><div><span style={{fontSize:12,fontWeight:700,color:T.teal,fontFamily:"monospace"}}>{w.id}</span><span style={{fontSize:11,color:T.textMuted,marginLeft:8}}>{w.tarih} · {w.tip}</span></div><Badge label={w.status} bg={w.status==="Teslim Edildi"?T.greenLight:T.amberLight} color={w.status==="Teslim Edildi"?T.green:T.amber}/></div>))}</Card>}
  </div>);
}

