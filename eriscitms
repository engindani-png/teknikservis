      <FInput label="Referans No (Sipariş/İrsaliye)" value={form.referans} onChange={upd("referans")} placeholder="SP-2026-..." mono/>
      <FTextarea label="Notlar" value={form.notlar} onChange={upd("notlar")} rows={2}/>
