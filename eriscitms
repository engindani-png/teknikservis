    if(form.serviceId)ctx.setServices(p=>p.map(s=>s.id===form.serviceId?{...s,quoteId:id,status:"Fiyat Verildi"}:s));
    onClose();
  };
  return(<Modal title="Yeni Teklif Oluştur" onClose={onClose} width={700}>
    <div style={{display:"flex",flexDirection:"column",gap:12}}>
