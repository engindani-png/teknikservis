            {days.map((d,i)=>{const isToday=d.getDate()===today.getDate()&&d.getMonth()===today.getMonth();return(<div key={i} style={{padding:"8px 10px",borderRight:i<6?`1px solid ${T.border}`:"none",textAlign:"center",background:isToday?"#F0FDFA":"transparent"}}>
