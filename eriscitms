              <div style={{fontSize:16,fontWeight:800,color:isToday?T.teal:T.text,fontFamily:"Sora,sans-serif"}}>{d.getDate()}</div>
            </div>);})}
          </div>
          {/* Hour rows */}
          <div style={{overflowY:"auto",maxHeight:"calc(100vh - 320px)"}}>
            {HOURS.map(h=>(<div key={h} style={{display:"grid",gridTemplateColumns:"60px repeat(7,1fr)",borderBottom:`1px solid ${T.border}`,minHeight:52}}>
